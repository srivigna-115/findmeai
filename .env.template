# FindMe Environment Variables Template
# Copy this file to create your .env files for each service

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# File: backend/.env
# ============================================

NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/findme?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRE=7d
BCRYPT_SALT_ROUNDS=12

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AI Service
AI_SERVICE_URL=http://localhost:5001
# Production: https://findme-ai-service.onrender.com

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=FindMe <noreply@findme.com>

# Frontend URL
FRONTEND_URL=http://localhost:3000
# Production: https://findme.onrender.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Matching Configuration
IMAGE_SIMILARITY_THRESHOLD=0.78
TEXT_SIMILARITY_THRESHOLD=0.70

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,audio/webm,audio/wav

# ============================================
# AI SERVICE ENVIRONMENT VARIABLES
# File: ai-service/.env
# ============================================

FLASK_ENV=production
PORT=5001

# Google Cloud Speech-to-Text
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Production (Render): /etc/secrets/google-credentials.json

# Model Configuration
MODEL_NAME=openai/clip-vit-base-patch32

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# File: frontend/.env
# ============================================

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
# Production: https://findme-backend.onrender.com/api

REACT_APP_SOCKET_URL=http://localhost:5000
# Production: https://findme-backend.onrender.com

# Firebase Web Configuration
REACT_APP_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
REACT_APP_FIREBASE_VAPID_KEY=BPXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXx

# ============================================
# HOW TO GET THESE VALUES
# ============================================

# MongoDB Atlas:
# 1. Create cluster at https://mongodb.com/atlas
# 2. Click "Connect" → "Connect your application"
# 3. Copy connection string

# Cloudinary:
# 1. Sign up at https://cloudinary.com
# 2. Dashboard shows Cloud Name, API Key, API Secret

# JWT Secret:
# Generate with: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Gmail App Password:
# 1. Enable 2FA on Gmail
# 2. Google Account → Security → App Passwords
# 3. Generate password for "Mail"

# Firebase:
# 1. Create project at https://console.firebase.google.com
# 2. Project Settings → Service Accounts → Generate new private key
# 3. Project Settings → General → Your apps → Web app config

# Google Cloud:
# 1. Create project at https://console.cloud.google.com
# 2. Enable Speech-to-Text API
# 3. IAM & Admin → Service Accounts → Create → Download JSON key

# ============================================
# SECURITY NOTES
# ============================================

# - NEVER commit .env files to Git
# - Use different secrets for dev/staging/production
# - Rotate secrets regularly
# - Use strong, random JWT secrets (32+ characters)
# - Keep Firebase private keys secure
# - Whitelist only necessary IPs in MongoDB Atlas
# - Use environment-specific Firebase projects
# - Enable 2FA on all service accounts
# - Monitor for unauthorized access
# - Backup environment variables securely

# ============================================
# PRODUCTION CHECKLIST
# ============================================

# [ ] All secrets are unique and strong
# [ ] No default/example values used
# [ ] MongoDB allows connections from deployment IPs
# [ ] CORS configured for production frontend URL
# [ ] Email credentials tested
# [ ] Firebase project is production-ready
# [ ] Google Cloud billing enabled
# [ ] All URLs use HTTPS in production
# [ ] Environment variables backed up securely
